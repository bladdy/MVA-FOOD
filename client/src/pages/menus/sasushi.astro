---
import { imageConfig } from "astro:assets";

import LayoutMenu from "@/layouts/LayoutMenu.astro";
import { sasushiRestaurant } from "@/consts/sasushi";
import sushiImage from "@/assets/uploads/Menu/sushi.jpg";
import sasushiLogo from "@/assets/uploads/Profile/sasushi/sasushi.png";
import sasushiBackground from "@/assets/uploads/Profile/sasushi/sasushibg.jpg";
import sasushiIcon from "@/assets/uploads/Profile/sasushi/sasushibg.ico";
import brushMask from "@/assets/uploads/Profile/sasushi/brush-mask.svg";

import sasushiComboBasico from "@/assets/uploads/Profile/sasushi/combo-basico.jpg";
import sasushiComboIntermedio from "@/assets/uploads/Profile/sasushi/combo-intermedio.jpg";
import sasushiComboPremium from "@/assets/uploads/Profile/sasushi/combo-premium.jpg";

const comboImages = {
  "combo-basico": sasushiComboBasico,
  "combo-intermedio": sasushiComboIntermedio,
  "combo-premium": sasushiComboPremium,
};

import sasushiCamarones from "@/assets/uploads/Profile/sasushi/camarones.jpeg";
import sasushiPlantainRoll from "@/assets/uploads/Profile/sasushi/plantain-roll.jpeg";
import sasushiPlantain from "@/assets/uploads/Profile/sasushi/plantain.jpeg";

import sasushiPollo2 from "@/assets/uploads/Profile/sasushi/pollo-2.jpeg";
import sasushiPollo3 from "@/assets/uploads/Profile/sasushi/pollo-3.jpeg";
import sasushiPollo4 from "@/assets/uploads/Profile/sasushi/pollo-4.jpeg";

import sasushiSalmon2 from "@/assets/uploads/Profile/sasushi/salmon-2.jpeg";
import sasushiSalmon3 from "@/assets/uploads/Profile/sasushi/salmon-3.jpeg";
import sasushiSalmon from "@/assets/uploads/Profile/sasushi/salmon.jpeg";

import sasushiVegano2 from "@/assets/uploads/Profile/sasushi/vegano-2.jpeg";
import sasushiVegano from "@/assets/uploads/Profile/sasushi/vegano.jpeg";

const productImages = {
  "roll-pollo": sasushiPollo2,
  "roll-salmon": sasushiSalmon,
  "roll-camaron": sasushiCamarones,
  "avocado-lover": sasushiVegano,
  "sweet-plantain": sasushiPlantain,
  "tofu-teriyaki": sasushiVegano2,
  "mushroom-crunch": sasushiPollo3,
};

const restaurant = sasushiRestaurant;

const description = `${restaurant.name} - ${restaurant.slogan}`;
const icon = sasushiIcon;
---

<LayoutMenu
  title={`Mr. Menús - ${restaurant.name}`}
  description={description}
  image={sasushiBackground.src}
  icon={icon}
>
  <main class="menu-page">
    <section class="hero">
      <img src={sasushiLogo.src} alt={restaurant.name} />

      <h1>{restaurant.name}</h1>

      <p>{restaurant.slogan}</p>
    </section>

    {
      restaurant.categories.map((category) => (
        <section class="category">
          <h2>{category.name}</h2>

          <div class="products">
            {category.items.map((item) => (
              <article class="product-card">
                <div class="product-image">
                  <img src={productImages[item.id as keyof typeof productImages].src}
                     alt={item.name} />
                </div>

                <div class="product-info">
                  <h3>{item.name}</h3>

                  <p>{item.description}</p>

                  <span>Disponible {item.availableTypes.join(" o ")}</span>

                  <div class="product-price">
                    <small>RD$</small>
                    <strong>{item.price}</strong>
                  </div>
                </div>
              </article>
            ))}
          </div>
        </section>
      ))
    }

    {
      (
        <section class="combos">
          <h2>Combos Sasushi</h2>

          <div class="combos-grid">
            {restaurant.combos.items.map((combo) => (
              <article class={`combo-card ${combo.id}`}>
                <div class="combo-header">
                  {combo.id === "combo-intermedio" && (
                    <div
                        class="combo-top-badge"
                        style={`--mask-url:url(${brushMask.src})`}
                      >
                        ⭐ MÁS VENDIDO
                      </div>
                  )}

                  {combo.id === "combo-premium" && (
                    <div class="combo-premium-badge">⭐ PREMIUM</div>
                  )}

                  <div
                      class="combo-title"
                      style={`--mask-url:url(${brushMask.src});
                        --mask-color: #8baa2a`}
                    >
                      <span>COMBO</span>
                      <h3>{combo.name.replace("Combo", "").trim()}</h3>
                    </div>

                  <div class="combo-person">👥 {combo.person}</div>
                </div>

                <div class="combo-image">
                  <img
                    src={comboImages[combo.id as keyof typeof comboImages].src}
                    alt={combo.nameProduct}
                  />
                </div>

                <div class="combo-product-name">{combo.nameProduct}</div>

                <ul class="combo-items">
                  {combo.availableTypes.map((item) => (
                    <li>{item}</li>
                  ))}
                </ul>

                <div class="combo-price">
                  <small>RD$</small>
                  <strong>{combo.price.toLocaleString()}</strong>
                </div>

                <div class="combo-footer">Incluye salsa especial y palitos</div>
              </article>
            ))}
          </div>
        </section>
      )
    }
    <footer class="menu-footer">
      <div class="footer-row">
        <div class="footer-item">
          <div class="footer-icon">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="icon icon-tabler icons-tabler-outline icon-tabler-bowl-chopsticks"
              ><path stroke="none" d="M0 0h24v24H0z" fill="none"></path><path
                d="M4 11h16a1 1 0 0 1 1 1v.5c0 1.5 -2.517 5.573 -4 6.5v1a1 1 0 0 1 -1 1h-8a1 1 0 0 1 -1 -1v-1c-1.687 -1.054 -4 -5 -4 -6.5v-.5a1 1 0 0 1 1 -1"
              ></path><path d="M19 7l-14 1"></path><path d="M19 2l-14 3"
              ></path></svg
            >
          </div>

          <div>
            <small>TODOS LOS ROLLS</small>
            <strong>INCLUYEN:</strong>
          </div>
        </div>

        <div class="footer-item">
          <div>
            <small>1 SALSA</small>
            <span>Elige tu favorita:</span>

            <div class="sauces">
              <span>TERIYAKI</span>
              <span>SOYA</span>
            </div>
          </div>
        </div>

        <div class="footer-item">
          <div class="footer-icon">🥢</div>

          <div>
            <small>PALILLOS</small>
            <strong>CHINOS</strong>
          </div>
        </div>
      </div>

      <div class="footer-row">
        <div class="footer-item">
          <div class="footer-icon">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="icon icon-tabler icons-tabler-outline icon-tabler-truck-delivery"
              ><path stroke="none" d="M0 0h24v24H0z" fill="none"></path><path
                d="M5 17a2 2 0 1 0 4 0a2 2 0 1 0 -4 0"></path><path
                d="M15 17a2 2 0 1 0 4 0a2 2 0 1 0 -4 0"></path><path
                d="M5 17h-2v-4m-1 -8h11v12m-4 0h6m4 0h2v-6h-8m0 -5h5l3 5"
              ></path><path d="M3 9l4 0"></path></svg
            >
          </div>

          <div>
            <small>PEDIDOS</small>
            <strong>POR ENCARGO</strong>
          </div>
        </div>

        <div class="footer-item">
          <div class="footer-icon whatsapp">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="icon icon-tabler icons-tabler-outline icon-tabler-brand-whatsapp"
              ><path stroke="none" d="M0 0h24v24H0z" fill="none"></path><path
                d="M3 21l1.65 -3.8a9 9 0 1 1 3.4 2.9l-5.05 .9"></path><path
                d="M9 10a.5 .5 0 0 0 1 0v-1a.5 .5 0 0 0 -1 0v1a5 5 0 0 0 5 5h1a.5 .5 0 0 0 0 -1h-1a.5 .5 0 0 0 0 1"
              ></path></svg
            >
          </div>

          <a
            href="https://wa.me/18293042081?text=Hola,%20quiero%20hacer%20un%20pedido"
            target="_blank"
            rel="noopener noreferrer"
            class="whatsapp-link"
          >
            <strong>829-304-2081</strong>
          </a>
        </div>

        <div class="footer-item">
          <div class="footer-icon instagram">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="icon icon-tabler icons-tabler-outline icon-tabler-brand-instagram"
              ><path stroke="none" d="M0 0h24v24H0z" fill="none"></path><path
                d="M4 8a4 4 0 0 1 4 -4h8a4 4 0 0 1 4 4v8a4 4 0 0 1 -4 4h-8a4 4 0 0 1 -4 -4l0 -8"
              ></path><path d="M9 12a3 3 0 1 0 6 0a3 3 0 0 0 -6 0"></path><path
                d="M16.5 7.5v.01"></path></svg
            >
          </div>
          <a
            href="https://www.instagram.com/sasushi.rd?utm_source=ig_web_button_share_sheet&igsh=ZDNlZDc0MzIxNw=="
            target="_blank"
            rel="noopener noreferrer"
            class="whatsapp-link"
          >
            <strong>Sasushi.rd</strong>
          </a>
        </div>
      </div>
    </footer>
  </main>
</LayoutMenu>

<style>
  .menu-page {
    min-height: 100vh;
    background: #050505;
    color: white;
    padding: 2rem 1rem 4rem;
  }

  .hero {
    text-align: center;
    margin-bottom: 3rem;
  }

  .hero img {
    width: 120px;
    margin: auto;
  }

  .hero h1 {
    font-size: 3rem;
    font-weight: 800;
    letter-spacing: 4px;
    margin-top: 1rem;
  }

  .hero p {
    color: #ccc;
    margin-top: 0.5rem;
  }

  .category {
    max-width: 1100px;
    margin: auto;
    margin-bottom: 4rem;
  }

  .category h2,
  .combos h2 {
    text-align: center;
    color: #8baa2a;
    font-size: 3rem;
    font-weight: 900;
    text-transform: uppercase;
    margin-bottom: 2rem;
  }

  .products {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .product-card {
    display: grid;
    grid-template-columns: 220px 1fr;

    background: #080808;
    border: 1px solid #556b1e;
    border-radius: 18px;
    overflow: hidden;
  }

  .product-image img {
    width: 100%;
    object-fit: fill;
    border-radius: 12px;
  }

  .product-info {
    position: relative;
    padding: 1.5rem 1rem;
    padding-bottom: 4rem;
  }

  .product-info h3 {
    color: white;
    font-size: 1.7rem;
    font-weight: 800;
    text-transform: uppercase;
  }

  .product-info p {
    margin-top: 0.75rem;
    color: #d8d8d8;
  }

  .product-info span {
    display: inline-block;
    margin-top: 1rem;
    color: #8baa2a;
    font-size: 0.9rem;
  }

  .product-price {
    position: absolute;
    right: 1rem;
    bottom: 1rem;

    display: flex;
    align-items: baseline;
    gap: 0.25rem;
  }

  .product-price small {
    color: #8baa2a;
    font-size: 0.8rem;
    font-weight: 700;
  }

  .product-price strong {
    color: white;
    font-size: 2rem;
    font-weight: 900;
    line-height: 1;
  }

  /* ==========================================
   COMBOS
========================================== */

  .combos {
    max-width: 1100px;
    margin: auto;
    margin-bottom: 4rem;
  }

  .combos-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0;
  }

  .combo-card {
    background: #050505;
    color: white;
    padding: 1.5rem;
    text-align: center;

    border: 1px solid #556b1e;
    border-radius: 18px;

    display: flex;
    flex-direction: column;
  }

  .combo-header {
    min-height: 140px;
  }

.combo-top-badge {
  position: relative;
  isolation: isolate;

  display: inline-block;

  color: #fff;
  font-size: 0.75rem;
  font-weight: 800;

  padding: 0.5rem 1.2rem;

  margin-bottom: 1rem;
}

.combo-top-badge::before {
  content: "";
  position: absolute;

  inset: -45px -25px;

  background: #f2b01e;

  -webkit-mask-image: var(--mask-url);
  -webkit-mask-repeat: no-repeat;
  -webkit-mask-position: center;
  -webkit-mask-size: 100% 100%;

  mask-image: var(--mask-url);
  mask-repeat: no-repeat;
  mask-position: center;
  mask-size: 100% 100%;

  z-index: -1;
}
  .combo-title {
    position: relative;
    isolation: isolate;
  }

  .combo-title span {
    display: block;
    color: #fff;
    font-size: 0.85rem;
    letter-spacing: 2px;
    margin-bottom: 0.3rem;
  }

  .combo-title h3 {
    margin: 0;
    font-size: 3rem;
    line-height: 1;
    font-weight: 900;
    text-transform: uppercase;
  }

  /* BASICO */
.combo-basico .combo-title::before {
  content: "";
  position: absolute;

  inset: -55px -30px;

  background: var(--mask-color);

  -webkit-mask-image: var(--mask-url);
  -webkit-mask-repeat: no-repeat;
  -webkit-mask-position: center;
  -webkit-mask-size: 100% 100%;

  mask-image: var(--mask-url);
  mask-repeat: no-repeat;
  mask-position: center;
  mask-size: 100% 100%;

  z-index: -1;
}

  /* PERSONA */
  .combo-person {
    margin-top: 1rem;
    color: #d0d0d0;
    font-size: 0.8rem;
    text-transform: uppercase;
  }

  /* IMAGEN */
  .combo-image {
    margin: 1.5rem 0;
  }

  .combo-image img {
    width: 100%;
    display: block;
    border-radius: 12px;
  }

  /* NOMBRE PRODUCTO */
  .combo-product-name {
    font-size: 1.8rem;
    font-weight: 900;
    text-transform: uppercase;
    margin-bottom: 1rem;
  }

  /* ITEMS */
  .combo-items {
    list-style: none;
    padding: 0;
    margin: 0;
    text-align: left;
    flex: 1;
  }

  .combo-items li {
    position: relative;
    padding-left: 1.5rem;
    margin-bottom: 0.8rem;
    color: #f3f3f3;
    font-size: 1.5rem;
  }

  .combo-items li::before {
    content: "✓";
    position: absolute;
    left: 0;
    color: #8baa2a;
    font-weight: bold;
  }

  /* PRECIO */
  .combo-price {
    margin-top: 1.5rem;

    display: flex;
    justify-content: center;
    align-items: baseline;
    gap: 0.25rem;
  }

  .combo-price small {
    color: #8baa2a;
    font-size: 1.5rem;
    line-height: 1;
    font-weight: 900;
  }

  .combo-price strong {
    color: white;
    font-size: 3.5rem;
    line-height: 1;
    font-weight: 900;
  }

  /* FOOTER COMBO */
  .combo-footer {
    margin-top: 1rem;
    padding-top: 1rem;
    border-top: 1px dashed #8baa2a;
    color: #cfcfcf;
    font-size: 0.85rem;
  }

  /* ==========================================
   FOOTER (menu)
========================================== */

  .menu-footer {
    max-width: 1100px;
    margin: 3rem auto 0;
  }

  .footer-row {
    display: flex;

    background: #080808;
    border: 1px solid #556b1e;
    border-radius: 14px;

    overflow: hidden;
  }

  .footer-row + .footer-row {
    margin-top: 0.8rem;
  }

  .footer-item {
    flex: 1;

    display: flex;
    align-items: center;
    gap: 1rem;

    padding: 0.9rem 1.2rem;

    min-height: 72px;
  }

  .footer-item:not(:last-child) {
    border-right: 1px dashed #556b1e;
  }

  .footer-icon {
    width: 42px;
    height: 42px;

    display: flex;
    align-items: center;
    justify-content: center;

    border: 1px solid #556b1e;
    border-radius: 50%;

    color: #8baa2a;
    flex-shrink: 0;
  }

  .footer-item small {
    display: block;
    color: #fff;
    font-size: 0.75rem;
    letter-spacing: 1px;
    line-height: 1.1;
  }

  .footer-item strong {
    color: #fff;
    font-size: 1rem;
    font-weight: 800;
    text-transform: uppercase;
  }

  .footer-item strong:last-child {
    color: #8baa2a;
  }

  .sauce-card,
  .sauces {
    display: flex;
    gap: 0.5rem;
  }

  .sauces {
    margin-top: 0.4rem;
  }

  .sauces span {
    border: 1px solid #556b1e;
    padding: 0.25rem 0.75rem;
    border-radius: 4px;
    font-size: 0.75rem;
    color: white;
  }

  .whatsapp {
    background: #25d366;
    color: white;
    border: none;
  }

  .instagram {
    border: none;
    color: white;
    background: linear-gradient(45deg, #f58529, #dd2a7b, #8134af, #515bd4);
  }

  .whatsapp-link {
    text-decoration: none;
    color: inherit;
  }

  .whatsapp-link strong {
    color: white;
    transition: color 0.2s ease;
  }

  .whatsapp-link:hover strong {
    color: #8baa2a;
  }

  /* ==========================================
   TABLET (max-width: 992px)
========================================== */

  @media (max-width: 992px) {
    .combos-grid {
      grid-template-columns: repeat(1, 1fr);
      gap: 1rem;
    }

    .combo-card {
      border: 1px solid #556b1e;
    }
  }

  /* ==========================================
   MOBILE (max-width: 768px)
========================================== */
  @media (max-width: 768px) {
    .product-card {
      grid-template-columns: 120px 1fr;
    }
    .product-image {
      padding: 0.5rem;

      display: flex;
      justify-content: center;
      align-items: center;
    }
    .product-info {
      padding: 1rem;
      padding-bottom: 3rem;
    }
    .product-info h3 {
      font-size: 1.2rem;
    }

    .product-price {
      right: 0.75rem;
      bottom: 0.75rem;
    }

    .product-price strong {
      font-size: 1.3rem;
    }
    .category h2 {
      font-size: 1.5rem;
    }
  }

  @media (max-width: 768px) {
    .combo-card {
      padding: 1.25rem;
    }

    .combo-title h3 {
      font-size: 2rem;
    }

    .combo-product-name {
      font-size: 1.4rem;
    }

    .combo-price strong {
      font-size: 2.5rem;
    }

    .combo-header {
      min-height: auto;
    }

    .footer-row {
      flex-direction: column;
    }

    .footer-item:not(:last-child) {
      border-right: none;
      border-bottom: 1px dashed #556b1e;
    }
  }
</style>
