---
export const prerender = false;
import { getRestauranteBySlug } from '@/Services/restauranteService.ts';
import LayoutMenu from "@/layouts/LayoutMenu.astro";
import MenuSectionWrapper from "@/React/MenuSectionWrapper.jsx";
import ShareButton from "@/React/Buttons/ShareButton";

let restaurant = null;
const { slug } = Astro.params;
try {
  if (typeof slug === "string") {
    restaurant = await getRestauranteBySlug(slug);
    if (!restaurant) {
        window.location.href = "/404";
      console.warn("Restaurante no encontrado para slug:", slug);
    }
  } else {
    console.warn("Parámetro 'slug' ausente o no válido:", slug);
  }
} catch (error) {
  console.error("Error al cargar restaurante:", error);
}
const description = `Perfil y menú de ${restaurant?.name ?? "Restaurante"}`;
const defaultImage = "/uploads/defaults/restaurant-default.jpg";

const ogImage = restaurant?.perfilImage
  ? `${restaurant.perfilImage}`
  : defaultImage;
---

<LayoutMenu
  title={`Mr. Menús - ${restaurant?.name}`}
  description={description}
  image={ogImage}
  icon={ogImage}
>

  <!-- LOADING SCREEN -->
  <div
    id="loading-screen"
    class="fixed inset-0 z-50 flex flex-col items-center justify-center bg-white transition-opacity duration-700"
  >
    <div class="w-32 h-32 rounded-full bg-gray-200 animate-shimmer mb-6" />
    <div class="w-48 h-6 rounded bg-gray-200 animate-shimmer mb-2" />
    <div class="w-32 h-4 rounded bg-gray-200 animate-shimmer" />
  </div>

  <!-- CONTENIDO -->
  <div id="main-content" class="opacity-0 transition-opacity duration-700">
  {
    restaurant ? (
      <>
        <!-- HERO SECTION -->
        <div class="relative min-h-[45vh] md:min-h-[55vh] flex items-end justify-center overflow-hidden">
          <img
            src={restaurant?.image}
            alt={restaurant.name}
            class="absolute inset-0 w-full h-full object-cover"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/40 to-transparent" />
          <div class="relative z-10 flex flex-col items-center text-center pb-8 md:pb-12 px-4">
            <img
              src={restaurant.perfilImage}
              alt={restaurant.name}
              class="w-20 h-20 md:w-28 md:h-28 rounded-full border-2 border-white/30 object-cover shadow-lg mb-3"
            />
            <h1 class="font-display text-4xl md:text-5xl lg:text-6xl font-bold text-white drop-shadow-sm leading-tight">
              {restaurant.name}
            </h1>
            {restaurant.slogan && (
              <p class="text-white/70 text-base md:text-lg mt-2 max-w-lg">{restaurant.slogan}</p>
            )}
            <div class="flex flex-wrap justify-center gap-2 mt-3">
              {restaurant.categorias?.map((c: { nombre: string }) => (
                <span class="px-3 py-1 text-xs font-medium bg-white/20 backdrop-blur-sm text-white rounded-full">
                  {c.nombre}
                </span>
              ))}
            </div>
            <div class="mt-3">
              <ShareButton title={restaurant.name} client:only="react" />
            </div>
          </div>
        </div>

        <!-- MENU SECTION -->
        <div class="max-w-3xl mx-auto px-4 pb-24">
          <MenuSectionWrapper
            restaurantId={restaurant.id}
            tiposEntrega={restaurant?.tiposEntrega ?? []}
            metodosPago={restaurant?.metodosPago ?? []}
            menu={restaurant?.menu ?? []}
            combos={restaurant?.combos ?? []}
            titulo="Nuestro Menú"
            client:load
          />
        </div>
      </>
    ) : (
      <div class="min-h-screen flex items-center justify-center p-10 text-center text-red-600 text-xl md:text-2xl">
        Restaurante no encontrado.
      </div>
    )
  }
    </div>

  <script>
    window.addEventListener("load", () => {
      const loading = document.getElementById("loading-screen");
      const content = document.getElementById("main-content");

      setTimeout(() => {
        loading?.classList.add("opacity-0");

        setTimeout(() => {
          loading?.classList.add("hidden");
          content?.classList.remove("opacity-0");
        }, 700);
      }, 1500);
    });
  </script>
</LayoutMenu>
