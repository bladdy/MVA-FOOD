---
import { restaurantePaxBeneficia } from "@/consts/restaurantePaxBeneficia.ts";
import LayoutMenu from "@/layouts/LayoutMenu.astro";

const recomendaciones = restaurantePaxBeneficia.platos.filter(
  (x) => x.recomendado,
);
---

<LayoutMenu title={`Mr. Menús - `} description={`Mr. Menús - `}>
  <div class="min-h-screen w-full bg-[#f7f7f7] overflow-x-hidden">
    <!-- HEADER -->

    <header class="sticky top-0 z-50 bg-white border-b border-gray-100 h-16">
      <div class="max-w-96 mx-auto px-4 py-3">
        <div class="flex items-center justify-between">
          <h1 class="font-semibold text-base truncate">
            {restaurantePaxBeneficia.nombre}
          </h1>

          <div class="flex items-center gap-4 text-lg">
            <div class="relative">
              <button
                id="languageButton"
                class="flex
                    items-center
                    gap-2
                    text-sm
                    font-medium">
                <img
                  id="selectedFlag"
                  src="/flags/es.svg"
                  alt="Español"
                  class="w-5 h-5 rounded-full object-cover"
                />

                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  class="w-4 h-4"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M19 9l-7 7-7-7"></path>
                </svg>
              </button>

              <div
                id="languageMenu"
                class="hidden
      absolute
      right-0
      top-full
      mt-2
      w-44
      bg-white
      rounded-xl
      shadow-lg
      border
      border-gray-100
      overflow-hidden
      z-50"
              >
                <button
                  class="language-option
        flex
        items-center
        gap-3
        w-full
        px-4
        py-3
        hover:bg-gray-50"
                  data-lang="es"
                  data-flag="/flags/es.svg"
                >
                  <img
                    src="/flags/es.svg"
                    class="w-5 h-5 rounded-full"
                    alt=""
                  />

                  Español
                </button>

                <button
                  class="language-option
        flex
        items-center
        gap-3
        w-full
        px-4
        py-3
        hover:bg-gray-50"
                  data-lang="en"
                  data-flag="/flags/us.svg"
                >
                  <img
                    src="/flags/us.svg"
                    class="w-5 h-5 rounded-full"
                    alt=""
                  />

                  English
                </button>

                <button
                  class="language-option
        flex
        items-center
        gap-3
        w-full
        px-4
        py-3
        hover:bg-gray-50"
                  data-lang="fr"
                  data-flag="/flags/fr.svg"
                >
                  <img
                    src="/flags/fr.svg"
                    class="w-5 h-5 rounded-full"
                    alt=""
                  />

                  Français
                </button>
              </div>
            </div>

            <a
              href={`https://wa.me/${restaurantePaxBeneficia.whatsapp}`}
              target="_blank"
              class="text-green-500"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="24"
                height="24"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="icon icon-tabler icons-tabler-outline icon-tabler-brand-whatsapp"
                ><path stroke="none" d="M0 0h24v24H0z" fill="none"></path><path
                  d="M3 21l1.65 -3.8a9 9 0 1 1 3.4 2.9l-5.05 .9"></path><path
                  d="M9 10a.5 .5 0 0 0 1 0v-1a.5 .5 0 0 0 -1 0v1a5 5 0 0 0 5 5h1a.5 .5 0 0 0 0 -1h-1a.5 .5 0 0 0 0 1"
                ></path></svg
              >
            </a>

            <a href={`tel:${restaurantePaxBeneficia.telefono}`}>
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="24"
                height="24"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="icon icon-tabler icons-tabler-outline icon-tabler-phone"
                ><path stroke="none" d="M0 0h24v24H0z" fill="none"></path><path
                  d="M5 4h4l2 5l-2.5 1.5a11 11 0 0 0 5 5l1.5 -2.5l5 2v4a2 2 0 0 1 -2 2a16 16 0 0 1 -15 -15a2 2 0 0 1 2 -2"
                ></path></svg
              >
            </a>

            <button id="shareButton">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="24"
                height="24"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="icon icon-tabler icons-tabler-outline icon-tabler-share"
                ><path stroke="none" d="M0 0h24v24H0z" fill="none"></path><path
                  d="M3 12a3 3 0 1 0 6 0a3 3 0 1 0 -6 0"></path><path
                  d="M15 6a3 3 0 1 0 6 0a3 3 0 1 0 -6 0"></path><path
                  d="M15 18a3 3 0 1 0 6 0a3 3 0 1 0 -6 0"></path><path
                  d="M8.7 10.7l6.6 -3.4"></path><path d="M8.7 13.3l6.6 3.4"
                ></path></svg
              >
            </button>
          </div>
        </div>
      </div>
    </header>

    <!-- CATEGORIAS -->

    <section class="sticky top-16 z-40 bg-white border-b border-gray-100">
      <div class="max-w-96 mx-auto">
        <div class="flex gap-4 overflow-x-auto px-3 py-3 scrollbar-hide">
          {
            restaurantePaxBeneficia.categorias.map((categoria) => (
              <button
                class="categoria-btn flex flex-col items-center shrink-0"
                data-category={categoria.id}
              >
                <div class="w-16 h-16 rounded-full p-[2px] bg-gradient-to-r from-orange-400 to-red-500">
                  <div class="w-full h-full rounded-full overflow-hidden bg-white">
                    {categoria.imagen ? (
                      <img
                        src={categoria.imagen}
                        alt={categoria.nombre}
                        class="w-full h-full object-cover"
                      />
                    ) : (
                      <div class="w-full h-full flex items-center justify-center text-2xl">
                        <svg
                          xmlns="http://www.w3.org/2000/svg"
                          width="24"
                          height="24"
                          viewBox="0 0 24 24"
                          fill="none"
                          stroke="currentColor"
                          stroke-width="2"
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          class="icon icon-tabler icons-tabler-outline icon-tabler-tools-kitchen-2"
                        >
                          <path stroke="none" d="M0 0h24v24H0z" fill="none" />
                          <path d="M19 3v12h-5c-.023 -3.681 .184 -7.406 5 -12m0 12v6h-1v-3m-10 -14v17m-3 -17v3a3 3 0 1 0 6 0v-3" />
                        </svg>
                      </div>
                    )}
                  </div>
                </div>

                <span class="text-[11px] mt-2 whitespace-nowrap">
                  {categoria.nombre}
                </span>
              </button>
            ))
          }
        </div>
      </div>
    </section>

    <!-- RECOMENDACIONES -->

    <section class="pt-4">
      <div class="max-w-96 mx-auto">
        <h2 class="font-semibold text-base px-4 mb-3">Recomendaciones</h2>

        <div class="flex gap-3 overflow-x-auto px-4 pb-4 scrollbar-hide">
          {
            recomendaciones.map((plato) => (
              <div class="relative shrink-0 w-[150px] h-[250px] rounded-2xl overflow-hidden shadow-sm">
                <img
                  src={plato.imagen}
                  alt={plato.nombre}
                  class="absolute inset-0 w-full h-full object-cover"
                />

                <div class="absolute inset-0 bg-gradient-to-t from-black via-black/40 to-transparent" />

                <div class="absolute bottom-3 left-3 right-3">
                  <h3 class="text-white text-sm font-semibold line-clamp-2">
                    {plato.nombre}
                  </h3>

                  <p class="text-white text-xs mt-1">${plato.precio}</p>
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <!-- MENU COMPLETO -->

    <section class="pb-24">
      <div class="max-w-96 mx-auto">
        {
          restaurantePaxBeneficia.categorias
            .filter((x) => x.id !== "all")
            .map((categoria) => (
              <section id={categoria.id} class="pt-6">
                <h2 class="font-bold text-lg px-4 mb-4">{categoria.nombre}</h2>

                <div class="space-y-5">
                  {restaurantePaxBeneficia.platos
                    .filter((plato) => plato.categoriaId === categoria.id)
                    .map((plato) => (
                      <article class="bg-white overflow-hidden">
                        <img
                          src={plato.imagen}
                          alt={plato.nombre}
                          class="w-full aspect-square object-cover"
                        />

                        <div class="p-4">
                          <div class="flex justify-between items-center">
                            <h3 class="font-semibold text-sm">
                              {plato.nombre}
                            </h3>

                            <button class="like-btn flex items-center gap-1 text-sm">
                              ❤️
                              <span>{plato.likes}</span>
                            </button>
                          </div>

                          <p class="font-bold text-lg mt-2">${plato.precio}</p>

                          <p class="text-sm text-gray-500 mt-2">
                            {plato.descripcion}
                          </p>
                        </div>
                      </article>
                    ))}
                </div>
              </section>
            ))
        }
      </div>
    </section>
  </div>
</LayoutMenu>
<script>
 import { initMenu } from "@/scripts/menu.js";

  initMenu();
</script>
<style>
  .scrollbar-hide::-webkit-scrollbar {
    display: none;
  }

  .scrollbar-hide {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
</style>
