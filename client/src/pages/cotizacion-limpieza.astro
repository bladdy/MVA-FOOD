---
import LayoutMenu from "@/layouts/LayoutMenu.astro"
---

<LayoutMenu title="Cotización para Sitio Web Institucional – Escuela de enfermería de la Cruz Roja" description="Cotización detallada para el desarrollo de un sitio web institucional para la Escuela de enfermería de la Cruz Roja, incluyendo estructura, funcionalidades, tiempos y costos.">

<!-- Contenedor imprimible -->
<article id="cotizacion" class="a4-page p-5 bg-white text-sm 
font-sans text-gray-900 border border-gray-300 flex flex-col justify-between">
  <div>
    <header class="flex justify-between items-center mb-6 border-b pb-2">
      <div>
        <h1 class="text-2xl font-bold">COTIZACIÓN <span class="text-orange-600">0004</span></h1>
        <p class="text-xs">25 de Febrero de 2026</p>
        <p class="text-xs mt-1"><strong>Vencimiento:</strong> 12 de Marzo de 2026</p>
      </div>
      <div class="text-right">
        <div class="mb-2 relative h-12">

            <img src="/ba-icon.png" alt="Logo" class="h-12 mb-2 absolute top-0 right-2" />
        </div>
        <p class="text-lg font-bold text-orange-600">$500.00 USD</p>
      </div>
    </header>

    <section class="mb-4">
      <div class="flex justify-between">
        <div>
          <p class="font-bold">Cliente</p>
          <p>Junior Rosa</p>
          <p>Pensilvania, Estados Unidos</p>
        </div>
        <div class="text-right">
          <p class="font-bold">Bladimir A. Almanzar V.</p>
          <p>866-142-5258</p>
          <p>bladdy34@gmail.com</p>
        </div>
      </div>
    </section>

    <section class="mt-4">
      <table class="w-full border-collapse border text-xs">
        <thead class="bg-gray-100">
          <tr>
            <th class="border px-2 py-1 text-left">MODULOS</th>
            <th class="border px-2 py-1 text-left">DETALLES</th>
            <th class="border px-2 py-1">TOTAL DE LÍNEA</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td class="border px-2 py-1 align-top">Desarrollo Web</td>
            <td class="border px-2 py-1">
              Diseño moderno y responsive<br>
              Hasta 5 secciones:<br>
              &nbsp;&nbsp;&nbsp;&bull;&nbsp;Inicio<br>
              &nbsp;&nbsp;&nbsp;&bull;&nbsp;Sobre Nosotros<br>
              &nbsp;&nbsp;&nbsp;&bull;&nbsp;Servicios<br>
              &nbsp;&nbsp;&nbsp;&bull;&nbsp;Contacto<br>
              &nbsp;&nbsp;&nbsp;&bull;&nbsp;Clientes<br>
              Formulario de contacto funcional<br>
              Multi-idioma<br>
              Optimización para móviles<br>
              Integración con redes sociales<br>
              Seguridad HTTPS<br>
            </td>
            <td class="border px-2 py-1 text-right"> $500.00 UDS</td>
          </tr>
          <tr>
            <td class="border px-2 py-1 align-top">Configuración Dominio</td>
            <td class="border px-2 py-1">
                Gestion y configuración del dominio (.com)<br>
                Configuración DNS<br>
                Conexión con servidor<br>
            </td>
            <td class="border px-2 py-1 text-right">$50.00 UDS</td>
          </tr>
          <tr>
            <td class="border px-2 py-1 align-top">Configuración Servidor</td>
            <td class="border px-2 py-1">
              Creación de Droplet<br>
              Instalación de Herramientas necesarias<br>
              Configuración de balanceador de carga<br>
              Configuración HTTPS (SSL)<br>
              Deploy del proyecto<br>
              Configuración de seguridad básica<br>
            </td>
            <td class="border px-2 py-1 text-right">$120.00 UDS</td>
          </tr>
          <tr>
            <td class="border px-2 py-1 align-top">SEO Inicial</td>
            <td class="border px-2 py-1">
              Meta tags optimizados<br>
              Sitemap<br>
              Robots<br>
              Configuración en Google Search Console<br>
              Optimización de velocidad básica<br>
              Palabras clave principales
            </td>
            <td class="border px-2 py-1 text-right">$150.00 UDS</td>
          </tr>
        </tbody>
      </table>
    </section>

    <section class="text-xs mt-6">
      <p><strong>Tiempo estimado de entrega:</strong> 2 a 3 semanas</p>
      <p><strong>30 días de soporte post-entrega gratis</strong></p>
      <p class="text-red-600 mt-2 hidden">*Descuento del 20% aplicable por pago anticipado</p>
    </section>

<section class="mt-4 border-t pt-4 text-sm">
  
  <div class="grid grid-cols-2 gap-6">
    
    <!-- IZQUIERDA -->
    <div class="space-y-1 text-xs">
      <p>Impuestos incluidos: No aplica</p>
      <p>Forma de pago: 50% inicial / 50% contra entrega</p>
    </div>

    <!-- DERECHA (Totales) -->
    <div class="space-y-1 text-right">
      <div class="flex justify-between">
        <span><strong>Total Neto:</strong></span>
        <span class="font-bold text-orange-600">$770.00 USD</span>
      </div>

      <div class="flex justify-between">
        <span><strong>Descuento:</strong></span>
        <span class="font-bold text-orange-600">-$270.00 USD</span>
      </div>

      <div class="flex justify-between border-t pt-1">
        <span><strong>Total Final:</strong></span>
        <span class="font-bold text-orange-600">$500.00 USD</span>
      </div>
    </div>

  </div>

</section>
  </div>

  <footer class="text-xs border-t pt-4 mt-6">
    <p class="mb-2">
      Esta cotización incluye el desarrollo del sitio web completo según las especificaciones mencionadas.
    </p>
    <div class="bg-green-100 text-green-800 p-2 text-center font-semibold">
      Esta cotización abarca todo el desarrollo del sitio web según lo solicitado en el documento de especificaciones del proyecto.
    </div>
  </footer>
</article>

<!-- Botón para imprimir solo el artículo -->
<div class="mt-6 text-center print:hidden">
  <button onclick="window.print()" class="bg-orange-600 hover:bg-orange-700 text-white font-semibold py-2 px-4 rounded shadow">
    🖨️ Imprimir Cotización
  </button>
</div>


</LayoutMenu>



<style is:global>
  @media print {
    body * {
      visibility: hidden;
    }
    #cotizacion, #cotizacion * {
      visibility: visible;
    }
    #cotizacion {
      position: absolute;
      left: 0;
      top: 0;
      width: 100%;
    }
    .print\:hidden {
      display: none !important;
    }
  }

  body {
    background-color: #f1f1f1;
    font-family: 'Segoe UI', sans-serif;
  }

  .a4-page {
    width: 210mm;
    min-height: 297mm;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    margin: auto;
    background: white;
  }

  table {
    font-size: 0.85rem;
  }
</style>