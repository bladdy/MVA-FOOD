---
import Restaurant from "../Restaurant.astro";

import logoRestaurant from "@/assets/uploads/Background/00eb3ede-68f2-482f-bc68-864a85204b49.png";

import sasushiLogo from "@/assets/uploads/Profile/sasushibg.jpg";

const restaurants = [
  {
    slug: "sasushi",
    name: "Sasushi",
    image: sasushiLogo,
  },
  {
    slug: "pollos-los-hermanos",
    name: "KFC",
    image: logoRestaurant,
  },
  {
    slug: "pollos-los-hermanos",
    name: "McDonalds",
    image: logoRestaurant,
  },
  {
    slug: "pollos-los-hermanos",
    name: "Pizza Hut",
    image: logoRestaurant,
  },
  {
    slug: "pollos-los-hermanos",
    name: "Dominos",
    image: logoRestaurant,
  },
  {
    slug: "pollos-los-hermanos",
    name: "Subway",
    image: logoRestaurant,
  },
  {
    slug: "pollos-los-hermanos",
    name: "Starbucks",
    image: logoRestaurant,
  },
  {
    slug: "pollos-los-hermanos",
    name: "Taco Bell",
    image: logoRestaurant,
  },
  {
    slug: "pollos-los-hermanos",
    name: "Carls Jr",
    image: logoRestaurant,
  },
];

// duplicamos para efecto infinito
const loopRestaurants = [...restaurants, ...restaurants];
---

<section id="features" class="py-20 overflow-hidden bg-white">
  <!-- Header -->
  <div class="text-center mb-14 px-4">
    <h2
      class="text-3xl sm:text-4xl md:text-5xl font-bold text-orange-600 mb-4"
    >
      Nuestros Clientes
    </h2>

    <p class="text-base sm:text-lg md:text-xl text-gray-600 max-w-3xl mx-auto">
      Descubre una variedad de restaurantes que ofrecen deliciosos platos.
    </p>
  </div>

  <!-- Carousel -->
  <div class="relative w-full overflow-hidden">
    <!-- Fade izquierdo -->
    <div
      class="absolute left-0 top-0 z-10 h-full w-10 sm:w-20 md:w-32 bg-gradient-to-r from-white to-transparent"
    >
    </div>

    <!-- Fade derecho -->
    <div
      class="absolute right-0 top-0 z-10 h-full w-10 sm:w-20 md:w-32 bg-gradient-to-l from-white to-transparent"
    >
    </div>

    <!-- Track -->
    <div class="carousel-track flex justify-center items-center gap-4 sm:gap-6 md:gap-8">
      {
        loopRestaurants.map((restaurant) => (
          <div
            class="flex-shrink-0 w-1/5 group"
          >
            <Restaurant href={`/menus/${restaurant.slug}`}>
              <div
                class="w-full h-[300px] overflow-hidden flex items-center justify-center"
              >
                <img
                  src={restaurant.image.src}
                  alt={restaurant.name}
                  title={restaurant.name}
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                />
              </div>
            </Restaurant>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  .carousel-track {
    animation: scroll 30s linear infinite;
  }

  .carousel-track:hover {
    animation-play-state: paused;
  }

  @keyframes scroll {
    from {
      transform: translateX(0);
    }

    to {
      transform: translateX(-50%);
    }
  }
.carousel-track > div {
      width: calc(20vw - 16px);
    }
  /* Móvil: máximo 2 visibles */
  @media (max-width: 640px) {
    .carousel-track > div {
      width: calc(85vw - 16px);
    }
  }
</style>